{
  "name": "@toncast/widget",
  "version": "0.0.1",
  "description": "Embeddable betting widget for Toncast — CDN-hosted IIFE bundle",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./styles/widget.css": "./dist/index.css",
    "./density-presets": {
      "types": "./dist/density-presets.d.ts",
      "import": "./dist/density-presets.js",
      "require": "./dist/density-presets.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "build:iife": "tsup --config tsup.iife.config.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "keywords": [
    "toncast",
    "ton",
    "widget",
    "betting",
    "tonconnect"
  ],
  "license": "MIT",
  "author": "Toncast",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@tanstack/react-query": "^5.62.0",
    "@ton/core": "^0.63.1",
    "@toncast/sdk": "*",
    "@toncast/sdk-react": "*",
    "@tonconnect/ui-react": "^2.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}

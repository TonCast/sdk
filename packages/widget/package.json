{
  "name": "@toncast/widget",
  "version": "0.0.2",
  "description": "Embeddable betting widget for Toncast — CDN-hosted IIFE bundle",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./styles/widget.css": "./dist/index.css",
    "./density-presets": {
      "types": "./dist/density-presets.d.ts",
      "import": "./dist/density-presets.js",
      "require": "./dist/density-presets.cjs"
    },
    "./color-math": {
      "types": "./dist/color-math.d.ts",
      "import": "./dist/color-math.js",
      "require": "./dist/color-math.cjs"
    },
    "./css-vars-builder": {
      "types": "./dist/css-vars-builder.d.ts",
      "import": "./dist/css-vars-builder.js",
      "require": "./dist/css-vars-builder.cjs"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.js",
      "require": "./dist/url.cjs"
    },
    "./use-prefers-color-scheme-dark": {
      "types": "./dist/use-prefers-color-scheme-dark.d.ts",
      "import": "./dist/use-prefers-color-scheme-dark.js",
      "require": "./dist/use-prefers-color-scheme-dark.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    }
  },
  "files": [
    "dist",
    "!dist/iife",
    "README.md"
  ],
  "sideEffects": [
    "./src/browser-globals.ts",
    "./dist/index.css",
    "./dist/iife/index.iife.js",
    "./dist/browser-globals.js",
    "./dist/browser-globals.cjs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:css": "node scripts/bundle-widget-css.mjs",
    "build:css:check": "node scripts/bundle-widget-css.mjs --check",
    "prebuild": "npm run build:css",
    "build": "tsup && npm run build:iife",
    "build:iife": "tsup --config tsup.iife.config.ts",
    "dev": "tsup --watch",
    "pretest": "npm --prefix ../sdk run build && npm --prefix ../sdk-react run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "toncast",
    "ton",
    "widget",
    "betting",
    "tonconnect"
  ],
  "license": "MIT",
  "author": "Toncast",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TonCast/sdk.git",
    "directory": "packages/widget"
  },
  "bugs": {
    "url": "https://github.com/TonCast/sdk/issues"
  },
  "homepage": "https://github.com/TonCast/sdk/tree/main/packages/widget#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ton/core": "0.63.1",
    "buffer": "6.0.3"
  },
  "peerDependencies": {
    "@radix-ui/react-slider": "^1.2.0",
    "@tanstack/react-query": "^5.0.0",
    "@toncast/sdk": "0.0.2",
    "@toncast/sdk-react": "0.0.2",
    "@tonconnect/ui-react": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tonconnect/ui-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-slider": "^1.2.0",
    "@tanstack/react-query": "^5.62.0",
    "@toncast/sdk": "0.0.2",
    "@toncast/sdk-react": "0.0.2",
    "@tonconnect/ui-react": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}

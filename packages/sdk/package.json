{
  "name": "@toncast/sdk",
  "version": "0.0.6",
  "description": "SDK for Toncast protocol: markets, bets, websocket, betting via @toncast/tx-sdk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.cjs"
      }
    },
    "./betting": {
      "import": {
        "types": "./dist/betting.d.ts",
        "default": "./dist/betting.js"
      },
      "require": {
        "types": "./dist/betting.d.ts",
        "default": "./dist/betting.cjs"
      }
    },
    "./streams": {
      "import": {
        "types": "./dist/streams.d.ts",
        "default": "./dist/streams.js"
      },
      "require": {
        "types": "./dist/streams.d.ts",
        "default": "./dist/streams.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "toncast",
    "ton",
    "pari",
    "prediction-market",
    "sdk"
  ],
  "license": "MIT",
  "author": "Toncast",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TonCast/sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/TonCast/sdk/issues"
  },
  "homepage": "https://github.com/TonCast/sdk/tree/main/packages/sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ston-fi/api": "0.32.0",
    "@ston-fi/sdk": "2.7.0",
    "@ton/core": "0.63.1",
    "@toncast/tx-sdk": "0.1.4",
    "zod": "^4.3.6"
  }
}

{
  "name": "@toncast/widget-loader",
  "version": "0.0.5",
  "description": "Loads the Toncast betting widget CDN bundle at runtime — analog of @ston-fi/omniston-widget-loader",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "toncast",
    "ton",
    "widget",
    "loader"
  ],
  "license": "MIT",
  "author": "Toncast",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TonCast/sdk.git",
    "directory": "packages/widget-loader"
  },
  "bugs": {
    "url": "https://github.com/TonCast/sdk/issues"
  },
  "homepage": "https://github.com/TonCast/sdk/tree/main/packages/widget-loader#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@toncast/widget": "0.0.5"
  }
}

# Optional: custom widget IIFE URL (defaults to production CDN in @toncast/widget-loader).
# VITE_WIDGET_CDN_URL=https://cdn.example.com/index.iife.js

# Optional: full URL to TonConnect manifest JSON (same idea as VITE_WIDGET_CDN_URL). If unset, the app uses a blob manifest with url = window.location.origin.
# VITE_TONCONNECT_MANIFEST_URL=https://your-cdn.example.com/tonconnect-manifest.json

# Optional: widget default language (`widget.language`), e.g. en, ru, es (must match SupportedLanguage in @toncast/widget-loader).
# VITE_WIDGET_LANGUAGE=ru

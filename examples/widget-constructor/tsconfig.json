{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@toncast/widget": ["../../packages/widget/src/index.ts"],
      "@toncast/widget/react": ["../../packages/widget/src/react.ts"],
      "@toncast/widget/density-presets": ["../../packages/widget/src/theme/densityPresets.ts"],
      "@toncast/widget/color-math": ["../../packages/widget/src/theme/colorMath.ts"],
      "@toncast/widget/css-vars-builder": ["../../packages/widget/src/theme/cssVarBuilder.ts"],
      "@toncast/widget/url": ["../../packages/widget/src/utils/url.ts"],
      "@toncast/widget/use-prefers-color-scheme-dark": [
        "../../packages/widget/src/utils/usePrefersColorSchemeDark.ts"
      ],
      "@toncast/widget/constants": ["../../packages/widget/src/constants.ts"],
      "@toncast/widget/styles/widget.css": ["../../packages/widget/src/styles/widget.css"],
      "@toncast/widget/*": ["../../packages/widget/src/*"],
      "@toncast/widget-loader": ["../../packages/widget-loader/src/index.ts"],
      "@toncast/sdk-react": ["../../packages/sdk-react/src/index.ts"],
      "@toncast/sdk": ["../../packages/sdk/src/index.ts"]
    }
  },
  "include": ["src", "tests", "../../packages/widget/src/css.d.ts"]
}

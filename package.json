{
  "name": "toncast-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo: @toncast/sdk + @toncast/sdk-react",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:widget-host": "node scripts/build-widget-host.mjs",
    "check": "npm run lint && npm run build && npm run typecheck && npm test",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "~7.3.2",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.4"
  },
  "license": "MIT"
}
